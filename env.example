# ══════════════════════════════════════════════════════════════════════════════
# SecurityHub Community Edition — Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
#
# Quick start (Docker — recommended):
#   cp env.example .env        # copy this file
#   $EDITOR .env               # fill in the REQUIRED fields
#   bash install.sh            # or: docker-compose up -d
#
# Quick start (bare-metal / local dev):
#   cp env.example .env
#   Set USE_DOCKER=False, POSTGRES_HOST=127.0.0.1, AUTH_COOKIE_SECURE=False
#   poetry install && poetry shell
#   python securityhub/manage.py migrate
#   python securityhub/manage.py first_setup
#   python securityhub/manage.py runserver
#
# NEVER commit .env — it contains secrets.
# The install.sh script fills this in interactively for you.
#
# ── Sections ──────────────────────────────────────────────────────────────────
#   1.  Deployment mode       (Docker vs bare-metal)
#   2.  Django core           (SECRET_KEY, DEBUG, hosts, CORS, CSRF)
#   3.  Database              (PostgreSQL — required for prod; SQLite fallback in dev)
#   4.  Cache                 (in-memory default; Redis recommended multi-worker)
#   5.  Storage               (local filesystem default; S3 optional)
#   6.  Auth & JWT            (cookie security, token lifetimes, password policy)
#   7.  Email                 (disabled by default)
#   8.  VulnDB / sync URLs    (GitHub raw URLs for reference data)
#   9.  Branding & site
#  10.  Admin account setup   (used by `manage.py first_setup`)
#  11.  Advanced tuning       (pagination, rate limits, upload limits)
# ══════════════════════════════════════════════════════════════════════════════


# ── 1. Deployment mode ───────────────────────────────────────────────────────

# True  → running via Docker Compose (nginx resolves as a service name)
# False → bare-metal / local dev
USE_DOCKER=True

# URL the Django process uses internally to fetch images embedded in
# PDF/DOCX reports. Docker: use the nginx service name. Bare-metal: use
# the same URL your Django process can reach its own static/media files on.
INTERNAL_BASE_URL=http://nginx


# ── 2. Django core ────────────────────────────────────────────────────────────

# REQUIRED — Generate a secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE_ME_replace_with_a_long_random_secret

# False in production; True only for local development.
DEBUG=False

# JSON array of allowed hostnames / IPs.
# NEVER include "*" in production — it bypasses host-header validation.
# Examples:
#   ALLOWED_HOST=["yourdomain.com","www.yourdomain.com"]
#   ALLOWED_HOST=["192.168.1.100","localhost"]
ALLOWED_HOST=["yourdomain.com","localhost"]

# Comma-separated list of origins browsers may call the API from.
# Must match exactly what users type in their browser (scheme + host + port).
# Examples:
#   CORS_ALLOWED_ORIGINS=https://yourdomain.com
#   CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Must include every origin that POSTs to the API (used for CSRF validation).
# Comma-separated; typically the same value as CORS_ALLOWED_ORIGINS.
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# JSON array of URLs the backend may fetch images from when building reports
# (SSRF allowlist). For Docker Compose this should be the nginx service URL.
# Bare-metal example: ["http://127.0.0.1:8000"]
WHITELIST_IP=["http://nginx"]

# Public URL of the frontend (used in invitation / reset email links).
FRONTEND_URL=https://yourdomain.com

# IANA timezone name — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
USER_TIME_ZONE=UTC


# ── 3. Database ───────────────────────────────────────────────────────────────
# PostgreSQL — REQUIRED for production.
# If ALL five POSTGRES_* vars are empty/absent, Django falls back to SQLite
# (suitable only for a quick local dev run — do not use in production).
#
# Docker Compose: POSTGRES_HOST is forced to "postgres" by docker-compose.yml
# so the value below only matters for bare-metal.

POSTGRES_USER=securityhub_user

# REQUIRED — choose a strong, unique password.
POSTGRES_PASSWORD=CHANGE_ME_db_password

POSTGRES_DB=securityhub

# Docker Compose: leave as "postgres" (the service name).
# Bare-metal: use "127.0.0.1" or your PostgreSQL server hostname.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432


# ── 4. Cache ──────────────────────────────────────────────────────────────────
# Leave REDIS_URL blank to use per-process in-memory cache (fine for a single
# worker). Set it when running multiple gunicorn workers so invalidations
# (e.g. VulnDB sync) reach every worker.
#
# The optional Redis password is used by docker-compose.dev.yml.
REDIS_PASSWORD=CHANGE_ME_redis_password

# Uncomment to enable Redis cache:
# REDIS_URL=redis://:${REDIS_PASSWORD}@cache:6379/
REDIS_URL=

# Cache TTL in seconds (default 900 = 15 minutes).
CACHE_TIMEOUT_SECONDS=900


# ── 5. Storage ────────────────────────────────────────────────────────────────
# Default: media files are stored on the local filesystem inside the container.
# Set USE_S3=True and fill in credentials to use S3-compatible object storage.

USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_ENDPOINT_URL=


# ── 6. Auth & JWT ─────────────────────────────────────────────────────────────

# True  → httpOnly auth cookies are Secure (required for HTTPS production).
# False → allow cookies over plain HTTP (local dev only).
AUTH_COOKIE_SECURE=True

# How long (minutes) an access token is valid before silent refresh.
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30

# How long (days) a refresh token is valid (= how long until forced re-login).
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Minimum password length enforced at account creation and password change.
PASSWORD_MIN_LENGTH=10


# ── 7. Email ──────────────────────────────────────────────────────────────────
# Set USE_EMAIL=False to disable all outbound email. Invitation tokens still
# work — admins must share them out-of-band (copy the link from the admin UI).

USE_EMAIL=False

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# Leave blank to use "SecurityHub <support@securityhub.community>"
DEFAULT_FROM_EMAIL=


# ── 8. VulnDB / reference data sync ──────────────────────────────────────────
# Raw GitHub URLs for syncing the vulnerability template library, project
# types, and report standards. Leave blank to skip auto-sync and manage
# entries manually through the admin panel.
#
# URL format: https://raw.githubusercontent.com/<org>/<repo>/<branch>/file.json
# VulnDB entries must have a "vulnerabilityname" key.
# Project type / report standard entries must have a "name" key.

VULNDB_GITHUB_URL=
PROJECT_TYPES_GITHUB_URL=
REPORT_STANDARDS_GITHUB_URL=

# CWE reference data used for autocomplete in vulnerability forms.
# Defaults to a public mirror; override to point at your own fork.
CWE_DATA_GITHUB_URL=https://raw.githubusercontent.com/APTRS/APTRS-CWE/main/cwe.json


# ── 9. Branding & site ───────────────────────────────────────────────────────

# Displayed in the API docs header and email footers.
SITE_NAME=SecurityHub
SITE_SUPPORT_EMAIL=support@securityhub.community


# ── 10. Admin account setup ──────────────────────────────────────────────────
# Used by `manage.py first_setup` (run automatically by install.sh).
# These are only read once during initial setup — changing them later has no
# effect unless you run `manage.py first_setup --force` again.

SETUP_USERNAME=admin
SETUP_EMAIL=admin@yourdomain.com
SETUP_FULL_NAME=Admin User
SETUP_POSITION=Security Engineer
SETUP_COMPANY_NAME=SecurityHub
# Leave blank to use the default (ChangeMe123!) — change it after login!
# Do NOT set this to an empty string; leave the key absent or provide a value.
SETUP_PASSWORD=ChangeMe123!


# ── 11. Advanced tuning (safe to leave at defaults) ──────────────────────────

# File upload size limits (megabytes).
MAX_UPLOAD_MB_IMAGE=10
MAX_UPLOAD_MB_DOCUMENT=50
MAX_UPLOAD_MB_SCAN=100
MAX_UPLOAD_MB_ARCHIVE=200
MAX_UPLOAD_MB_DEFAULT=50

# API pagination defaults.
PAGINATION_STANDARD_PAGE_SIZE=25
PAGINATION_STANDARD_MAX_PAGE_SIZE=100
PAGINATION_LARGE_PAGE_SIZE=100
PAGINATION_LARGE_MAX_PAGE_SIZE=500
PAGINATION_SMALL_PAGE_SIZE=10
PAGINATION_SMALL_MAX_PAGE_SIZE=50
PAGINATION_CURSOR_DEFAULT_LIMIT=25
PAGINATION_CURSOR_MAX_LIMIT=100

# DRF throttle rates (format: "<count>/<period>").
THROTTLE_RATE_ANON=50/minute
THROTTLE_RATE_USER=200/minute
THROTTLE_RATE_LOGIN=5/minute
THROTTLE_RATE_FILE_UPLOAD=10/minute
THROTTLE_RATE_SEARCH=30/minute
THROTTLE_RATE_ADMIN=500/minute
THROTTLE_RATE_BURST=100/minute
