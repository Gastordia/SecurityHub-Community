TODO/
tools/temp/
utils/temp/
run.sh
securityhub/nohup.out
securityhub/helloword.docx
securityhub/report-tester.docx
securityhub/project/report.docx
securityhub/templates/.~lock.report.docx#
Features.txt

# Media files (POC images)
securityhub/media/poc/**

# Keep lib directories
!securityhub/lib/

