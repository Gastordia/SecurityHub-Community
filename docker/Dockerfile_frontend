# syntax=docker/dockerfile:1.4

# ============================================================================
# Stage 1: Build the Vite.js project
# ============================================================================
FROM node:18-alpine AS builder

WORKDIR /app

# Install build dependencies
RUN apk add --no-cache \
    python3 \
    make \
    g++

# Copy package files first for better layer caching
COPY frontend/package.json frontend/package-lock.json* ./

# Copy workspace packages directory if it exists
# npm workspaces require packages/ to be present during install
# Using find to handle optional directory gracefully
RUN mkdir -p packages || true

# Copy workspace packages (will fail silently if doesn't exist, which is OK)
# We'll handle this in the install step
# COPY frontend/packages ./packages/ 2>/dev/null || true

# Install dependencies using BuildKit cache mount
# npm automatically handles workspaces if packages/ directory exists
RUN --mount=type=cache,target=/root/.npm \
    npm ci --prefer-offline --no-audit --no-fund

# Copy frontend source code (after dependencies for better caching)
COPY frontend/ ./

# Set production environment variables
# Vite reads VITE_* prefixed variables from process.env at build time
ARG VITE_APP_API_URL=
ARG VITE_APP_ENV=production

# Make environment variables available to build process
ENV VITE_APP_API_URL=$VITE_APP_API_URL
ENV VITE_APP_ENV=$VITE_APP_ENV

# Build the application
# Vite will embed these env vars into the built application
RUN --mount=type=cache,target=/app/node_modules/.vite \
    npm run build

# Verify build output exists
RUN test -d dist && echo "✅ Build successful: dist directory exists" || (echo "❌ Build failed: dist directory not found" && exit 1)

# ============================================================================
# Stage 2: Production nginx image
# ============================================================================
FROM nginx:1.25-alpine AS production

# Install runtime tools in one layer
RUN apk add --no-cache curl openssl && \
    rm -rf /var/cache/apk/*

# Remove default nginx configuration
RUN rm /etc/nginx/conf.d/default.conf

# Copy built assets from build stage
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx configuration
COPY scripts/nginx.conf /etc/nginx/conf.d/default.conf

# Generate self-signed SSL certificates for development
# For production, use proper certificates (Let's Encrypt, etc.)
RUN \
    mkdir -p /etc/nginx/certs && \
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
      -keyout /etc/nginx/certs/selfsigned.key \
      -out /etc/nginx/certs/selfsigned.crt \
      -subj "/C=US/ST=State/L=City/O=Organization/CN=localhost" && \
    chmod 600 /etc/nginx/certs/selfsigned.key && \
    chmod 644 /etc/nginx/certs/selfsigned.crt

# Copy SSL certificates if they exist (optional, won't fail if missing)
# For production, uncomment and provide proper certificates:
# COPY --chown=root:root Certificate /etc/nginx/certs/ || true

# Create nginx cache and log directories
RUN mkdir -p /var/cache/nginx/client_temp \
             /var/cache/nginx/proxy_temp \
             /var/cache/nginx/fastcgi_temp \
             /var/cache/nginx/uwsgi_temp \
             /var/cache/nginx/scgi_temp \
             /var/log/nginx \
    && chown -R nginx:nginx /var/cache/nginx \
    && chown -R nginx:nginx /var/log/nginx

# Expose ports
EXPOSE 80 443

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl --fail --silent http://localhost/ || exit 1

# Run nginx in foreground
CMD ["nginx", "-g", "daemon off;"]
