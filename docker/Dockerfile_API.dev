# syntax=docker/dockerfile:1.4
# ============================================================================
# Dev image — code is bind-mounted at runtime, NOT baked in.
# Hot-reload via Django runserver.  Do NOT use in production.
# ============================================================================
FROM ubuntu:22.04

ENV TZ=UTC \
    DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONFAULTHANDLER=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        build-essential \
        tzdata \
        locales \
        sqlite3 \
        fontconfig-config \
        libjpeg-turbo8 \
        libxrender1 \
        libfontconfig1 \
        libxext6 \
        fontconfig \
        xfonts-75dpi \
        xfonts-base \
        python3 \
        python3-dev \
        python3-pip \
        curl \
        libpango-1.0-0 \
        libharfbuzz0b \
        libpangoft2-1.0-0 \
        postgresql-client \
        libpq-dev \
        libmagic1 \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

WORKDIR /home/securityhub/securityhub

# Install pip + Poetry
RUN python3 -m pip install --upgrade --no-cache-dir pip setuptools wheel packaging && \
    pip install --no-cache-dir poetry==1.8.3

RUN poetry config virtualenvs.create false && \
    poetry config cache-dir /tmp/poetry-cache

# Copy only dep files so this layer is cached unless deps change
COPY pyproject.toml poetry.lock* ./
COPY requirements.txt ./

RUN --mount=type=cache,target=/tmp/poetry-cache \
    --mount=type=cache,target=/root/.cache/pip \
    PIP_NO_BUILD_ISOLATION=1 poetry install --no-root --no-interaction --no-ansi --only=main && \
    pip install --no-cache-dir -r requirements.txt

# Create dirs that the app expects; source code arrives via volume mount
RUN mkdir -p /home/securityhub/securityhub/securityhub/static \
             /home/securityhub/securityhub/securityhub/media

EXPOSE 8000

# backend.dev.sh is bind-mounted from ./scripts at runtime.
CMD ["sh", "-c", "chmod +x /home/securityhub/securityhub/scripts/backend.dev.sh && exec bash /home/securityhub/securityhub/scripts/backend.dev.sh"]
